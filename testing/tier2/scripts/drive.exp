#!/usr/bin/expect -f
# Drive rmosh-client through a PTY (expect allocates one), typing a marker before and after a
# mid-session network roam, and confirm both round-trip — i.e. the session survived the roam.
#
# Usage (inside the client container):  expect /scripts/drive.exp <server-id> <relay-url>
# Exit 0 = both markers seen (session resumed after roam); non-zero = failure.

set timeout 30
set server_id [lindex $argv 0]
set relay     [lindex $argv 1]

spawn rmosh-client $server_id --relay-url $relay --predict never --key-file /tmp/client.key

# Let it connect + initial-sync, then type the pre-roam marker.
sleep 3
send "echo ROAM_BEFORE_MARKER\r"
expect {
    "ROAM_BEFORE_MARKER" {}
    timeout { puts "\nFAIL: pre-roam marker never rendered"; exit 1 }
}

# The host moves the client's network here (roaming-test.sh sleeps in lock-step).
puts "\n--- pre-roam OK; awaiting network move ---"
sleep 12

# After the roam, the QUIC connection must migrate and the session must still work.
send "echo ROAM_AFTER_MARKER\r"
expect {
    "ROAM_AFTER_MARKER" { puts "\nOK: session resumed after roam"; exit 0 }
    timeout { puts "\nFAIL: session did not resume after roam"; exit 1 }
}
