# Copy to .env and `set -a; . ./.env; set +a` (or export manually) before running the harness.
# All optional except KOH_ANDROID_EMULATOR, which is the master opt-in switch.

# Master switch — the harness is a clean no-op unless this is exactly "1".
KOH_ANDROID_EMULATOR=1

# Android SDK / NDK (macOS + Homebrew defaults shown; override for other setups).
ANDROID_HOME=/opt/homebrew/share/android-commandlinetools
ANDROID_NDK_HOME=/opt/homebrew/share/android-ndk
JAVA_HOME=/opt/homebrew/opt/openjdk

# Target a specific device/emulator if more than one is attached (else the first is used).
#ANDROID_SERIAL=emulator-5554

# Build / runtime knobs (defaults are sensible).
#KOH_ANDROID_API=24            # min API of the built binary (must be <= the emulator image API)
#KOH_DEVICE_BIN=/data/local/tmp/koh
#KOH_ADB_TIMEOUT=30            # seconds, cap per non-blocking adb call
#KOH_BOOT_TIMEOUT=300         # seconds to wait for the emulator to finish booting
#KOH_FORCE_BUILD=1            # force a rebuild even if the binary exists
#KOH_DEVICE_SHELL=/system/bin/sh   # session shell on the device (Android has no /bin/sh)

# Stress suite (testing/android/scripts/run-stress.sh). Intensity + per-test overrides.
#KOH_STRESS_LEVEL=full        # quick (default, CI) | full (heavy soak: larger counts/longer runs)
#KOH_STRESS_BIND_ITERS=20         # bind-storm: endpoint binds
#KOH_STRESS_CHURN_CYCLES=30       # connection-churn: connect/disconnect cycles
#KOH_STRESS_CLIENTS=8             # concurrent-clients: simultaneous distinct clients
#KOH_STRESS_AUTH_ATTEMPTS=10      # auth flood: failed-auth attempts
#KOH_STRESS_SIGNAL_ROUNDS=12      # signal-storm: start/drain rounds
#KOH_STRESS_LINES=20000           # throughput: lines flooded
#KOH_STRESS_LONGEVITY_SECS=40     # memory-longevity: flood duration (seconds)
#KOH_STRESS_RECONNECT_ROUNDS=2    # link-drop resilience: kill-server rounds
#KOH_STRESS_FREEZE_SECS=15        # client-freeze: SIGSTOP duration (must be < the 300s idle timeout)

# Best-effort stress tests (self-SKIP unless their opt-in + prerequisites are present).
#KOH_STRESS_NETEM=1               # netem chaos soak + roaming tests: enable (needs `adb root` + `tc`/netem)
#KOH_STRESS_NETEM_SOAK_SECS=72    # chaos soak: total duration cycling adverse conditions (full: 300)
#KOH_STRESS_NETEM_PHASE_SECS=8    # chaos soak: seconds per condition (keep < the 300s idle timeout)
#KOH_STRESS_ROAM_OUTAGE_SECS=6    # roaming: total-outage duration (must be < the 300s idle timeout)
#KOH_ANDROID_NET=1                # relay/discovery test: enable (needs the emulator to reach the internet)
